# Database connection string for PostgreSQL
DATABASE_URL=postgresql://<username>:<password>@<host>:<port>/<database>

# Secret key for JWT authentication
JWT_SECRET=<random_secret_key>

# Backend server port
PORT=8000

# Frontend environment variable for API URL
VITE_API_URL=http://localhost:8000

# PostgreSQL environment variables for pgvector service
POSTGRES_USER=<postgres_user>
POSTGRES_PASSWORD=<postgres_password>
POSTGRES_DB=<postgres_db>

# OpenAI API key for LLM integration (if applicable)
OPENAI_API_KEY=<your_openai_api_key>

# Anthropic API key for LLM integration (if applicable)
ANTHROPIC_API_KEY=<your_anthropic_api_key>

# Pinecone API key for vector database integration (if applicable)
PINECONE_API_KEY=<your_pinecone_api_key>

# Secret key for backend services (used in backend/services/auth.py)
SECRET_KEY=<random_secret_key>